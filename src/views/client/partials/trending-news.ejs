<div class="mb-3">
  <div class="section-title mb-0">
    <h4 class="m-0 text-uppercase font-weight-bold">Tin tức thịnh hành</h4>
  </div>
  <div class="bg-white border border-top-0 p-3">
    <!--Trending News Item Start-->
    <% if (thinhHanh && thinhHanh.length > 0) { %>
    <% thinhHanh.forEach(function(news) { %>
    <div class="d-flex align-items-center bg-white mb-3" style="height: 110px">
      <div
        class="w-100 h-100 px-3 d-flex flex-column justify-content-center border border-left-0"
      >
        <div class="mb-2">
          <a
            class="badge badge-primary text-uppercase font-weight-semi-bold p-1 mr-2"
            href="category/<%= news.id_danh_muc %>"
            ><%= news.ten_danh_muc %></a
          >
          <a class="text-body" href=""><small><%= news.ngay_dang %></small></a>
        </div>
        <a class="h6 m-0 text-secondary text-uppercase font-weight-bold" href="/single/<%= news.id %>"
          ><%= news.tieu_de %></a
        >
      </div>
    </div>
    <% }); %>
    <% } %>
    <!--Trending News Item End-->
  </div>
</div>
