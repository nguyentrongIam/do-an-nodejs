<div class="container-fluid">
  <div class="row">
    <div class="col-lg-12 px-0">
      <div class="owl-carousel main-carousel position-relative">
        <!--News Card Slider Start-->
        <% if (tatCa && tatCa.length > 0) { %>
        <% tatCa.forEach(function(news) { %>
          <div class="position-relative overflow-hidden" style="height: 500px">
            <img
              class="img-fluid h-100"
              src="<%= news.link_hinh_anh %>"
              style="object-fit: cover"
            />
            <div class="overlay">
              <div class="mb-2">
                <a
                  class="badge badge-primary text-uppercase font-weight-semi-bold p-2 mr-2"
                  href="category/<%= news.id_danh_muc %>"
                  ><%= news.ten_danh_muc %></a
                >
                <a class="text-white" href=""><%= news.ngay_dang %></a>
              </div>
              <a class="h2 m-0 text-white text-uppercase font-weight-bold" href="/single/<%= news.id %>"
                ><%= news.tieu_de %></a
              >
            </div>
          </div>
        <% }); %>
        <% } %>
        <!--News Card Slider End-->
      </div>
    </div>
  </div>
</div>
