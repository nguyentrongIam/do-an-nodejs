<div class="mb-3">
  <div class="section-title mb-0">
    <h4 class="m-0 text-uppercase font-weight-bold">Chủ đề</h4>
  </div>
  <div class="bg-white border border-top-0 p-3">
    <div class="d-flex flex-wrap m-n1">
    <% if (danhMuc && danhMuc.length > 0) { %>
        <% danhMuc.forEach(function(cat) { %>
            <a href="/category/<%= cat.id_danh_muc %>" class="btn btn-sm btn-outline-secondary m-1">
                <%= cat.ten_danh_muc %>
            </a>
        <% }); %>
    <% } %>
</div>
  </div>
</div>
